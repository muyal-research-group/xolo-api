# MongoDB container configuration.
# Uncomment root credentials if you also enable auth in db/mongod.conf
# and update XOLO_MONGODB_URI in deploy/env/app.prod.env accordingly.

MONGO_INITDB_DATABASE=xolo
# MONGO_INITDB_ROOT_USERNAME=xolo
# MONGO_INITDB_ROOT_PASSWORD=replace-with-a-strong-mongo-password
