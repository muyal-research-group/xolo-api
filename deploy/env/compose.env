# Compose interpolation values.
# Use with: docker compose --env-file deploy/env/compose.env up -d

XOLO_COMPOSE_PROJECT_NAME=xolo

XOLO_DOCKERFILE=Dockerfile
XOLO_IMAGE=xolo-api:latest
XOLO_APP_ENV_FILE=./deploy/env/app.prod.env

XOLO_API_CONTAINER_NAME=xolo-api
XOLO_HOST=0.0.0.0
XOLO_PORT=10000
XOLO_API_PUBLIC_PORT=10000
XOLO_UVICORN_LOG_LEVEL=info

XOLO_MONGO_IMAGE_TAG=8-noble
XOLO_MONGO_CONTAINER_NAME=xolo-mongodb
XOLO_MONGODB_PUBLIC_PORT=27018

XOLO_REDIS_IMAGE_TAG=7.0.11-alpine
XOLO_REDIS_CONTAINER_NAME=xolo-redis
XOLO_REDIS_PUBLIC_PORT=6379

XOLO_NETWORK_NAME=xolo-net
XOLO_MONGO_VOLUME_NAME=xolo-mongodb-data
XOLO_REDIS_VOLUME_NAME=xolo-redis-data
XOLO_DATA_VOLUME_NAME=xolo-data
XOLO_LOG_VOLUME_NAME=xolo-logs
