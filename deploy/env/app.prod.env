# Xolo production/container runtime template.
# Replace every placeholder secret and hostname before real deployment.

# Core runtime
XOLO_LICENSE_SECRET_KEY=replace-with-a-long-random-license-secret
XOLO_ACL_OUTPUT_PATH=/xolo
XOLO_ACL_FILENAME=xolo-acl.enc
XOLO_ACL_DAEMON_HEARTBEAT=15min

# Logging
XOLO_LOG_NAME=xoloapi
XOLO_LOG_INTERVAL=24
XOLO_LOG_WHEN=h
XOLO_LOG_PATH=/app/log

# OpenAPI
XOLO_OPENAPI_PREFIX=
XOLO_OPENAPI_TITLE=Xolo: Identity & Access Management API
XOLO_OPENAPI_VERSION=0.0.1
XOLO_OPENAPI_SUMMARY=Identity and Access Management API for Xolo Platform
XOLO_OPENAPI_DESCRIPTION=This API enables the management of users, roles, and permissions within the Xolo Platform.
XOLO_OPENAPI_LOGO=

# HTTP / CORS
XOLO_CORS_ALLOW_ORIGINS=*
XOLO_CORS_CREDENTIALS=true
XOLO_CORS_ALLOW_METHODS=*
XOLO_CORS_ALLOW_HEADERS=*

# MongoDB
XOLO_MONGODB_URI=mongodb://xolo-db:27017/xolo
XOLO_MONGODB_DATABASE_NAME=xolo

# Redis (URI preferred; host/port are fallback inputs for URI construction)
XOLO_CACHE_REDIS_HOST=xolo-cache
XOLO_CACHE_REDIS_PORT=6379
XOLO_CACHE_REDIS_URI=redis://xolo-cache:6379/0

# Auth / security
XOLO_SUPER_ADMIN_TOKENS=replace-with-admin-token-1,replace-with-admin-token-2
XOLO_JWT_EXPIRE_MINUTES=15
XOLO_JWT_SECRET=replace-with-a-long-random-jwt-secret
XOLO_JWT_ALGORITHM=HS256
XOLO_ADMIN_UI_SESSION_SECRET=replace-with-a-long-random-admin-ui-session-secret
XOLO_ADMIN_UI_SESSION_COOKIE_NAME=xolo_admin_session
XOLO_ADMIN_UI_SESSION_MAX_AGE=3600
XOLO_ADMIN_UI_SESSION_SECURE=true
XOLO_LEGACY_API_KEY=replace-with-legacy-api-key-if-used

# Password reset / email delivery
XOLO_PASSWORD_RESET_TOKENS_COLLECTION_NAME=password_reset_tokens
XOLO_PASSWORD_RESET_TOKEN_EXPIRES_IN=15min
XOLO_PASSWORD_RESET_URL_BASE=https://your-frontend.example.com/reset-password
XOLO_EMAIL_PROVIDER=smtp
XOLO_PASSWORD_RESET_MAIL_SUBJECT=Xolo password reset
XOLO_WELCOME_MAIL_SUBJECT=Welcome to Xolo
XOLO_SMTP_HOST=smtp.example.com
XOLO_SMTP_PORT=587
XOLO_SMTP_USERNAME=replace-with-smtp-username
XOLO_SMTP_PASSWORD=replace-with-smtp-password
XOLO_SMTP_USE_TLS=true
XOLO_SMTP_USE_SSL=false
XOLO_MAIL_SENDER_ADDRESS=no-reply@example.com
XOLO_MAIL_SENDER_NAME=Xolo IAM
XOLO_CLOUDFLARE_ACCOUNT_ID=
XOLO_CLOUDFLARE_EMAIL_API_TOKEN=

# Main collections
XOLO_USERS_COLLECTION_NAME=users
XOLO_CREDENTIALS_COLLECTION_NAME=credentials
XOLO_LICENSES_COLLECTION_NAME=licenses
XOLO_SCOPES_COLLECTION_NAME=scopes
XOLO_SCOPE_USER_COLLECTION_NAME=scope_user
XOLO_GROUPS_COLLECTION_NAME=groups
XOLO_GROUP_MEMBERS_COLLECTION_NAME=group_members
XOLO_ACCESS_POLICIES_COLLECTION_NAME=access_policies
XOLO_SECURITY_GROUPS_COLLECTION_NAME=security_groups
XOLO_API_KEYS_COLLECTION_NAME=api_keys

# ACL
XOLO_ACL_RESOURCE_POLICIES_COLLECTION_NAME=acl_resource_policies
XOLO_ACL_GROUPS_COLLECTION_NAME=acl_groups
XOLO_ACL_GROUP_MEMBERS_COLLECTION_NAME=acl_group_members

# ABAC / NGAC / RBAC
XOLO_ABAC_COLLECTION_NAME=abac_policies
XOLO_NGAC_NODES_COLLECTION=ngac_nodes
XOLO_NGAC_ASSIGNMENTS_COLLECTION=ngac_assignments
XOLO_NGAC_ASSOCIATIONS_COLLECTION=ngac_associations
XOLO_RBAC_ROLES_COLLECTION_NAME=rbac_roles
XOLO_RBAC_ASSIGNMENTS_COLLECTION_NAME=rbac_assignments
